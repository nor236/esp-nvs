_default:
    @just --list

# Chip → target triple mapping
_CHIP_TARGET := {
    "esp32":   "xtensa-esp32-none-elf",
    "esp32s2": "xtensa-esp32s2-none-elf",
    "esp32s3": "xtensa-esp32s3-none-elf",
    "esp32c2": "riscv32imc-unknown-none-elf",
    "esp32c3": "riscv32imc-unknown-none-elf",
    "esp32c5": "riscv32imac-unknown-none-elf",
    "esp32c6": "riscv32imac-unknown-none-elf",
    "esp32c61": "riscv32imac-unknown-none-elf",
    "esp32h2": "riscv32imac-unknown-none-elf",
}

# Build the example for a specific chip.
# Usage: just build esp32c6
build chip="esp32c61":
    cargo build -p example --features {{chip}} --target {{ _CHIP_TARGET[chip] }}

# Build + flash (via espflash runner) for a specific chip.
# Usage: just run esp32c3
run chip="esp32c61":
    cargo run -p example --features {{chip}} --target {{ _CHIP_TARGET[chip] }}

# Build release for a specific chip.
build-release chip="esp32c61":
    cargo build -p example --release --features {{chip}} --target {{ _CHIP_TARGET[chip] }}

# List supported chips and their targets.
list-chips:
    @just --list
    @echo ""
    @echo "Supported chips:"
    @for chip in esp32 esp32s2 esp32s3 esp32c2 esp32c3 esp32c5 esp32c6 esp32c61 esp32h2; do \
        target="{{ _CHIP_TARGET[chip] }}"; \
        echo "  $$chip  →  $$target"; \
    done
